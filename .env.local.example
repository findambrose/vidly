# ========================================
# ShortsForge MVP Environment Variables
# ========================================
# Copy this file to .env.local and fill in your actual values

# ========================================
# Supabase Configuration
# ========================================
# Get these from your Supabase project settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ========================================
# AI & Video Generation APIs
# ========================================
# OpenRouter API for script generation (using free Kimi K2 model)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key

# ElevenLabs API for voice generation
# Get from: https://elevenlabs.io/docs/api-reference/authentication
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Pexels API for stock videos/images
# Get from: https://www.pexels.com/api/
PEXELS_API_KEY=your-pexels-api-key

# Shotstack API for video editing and rendering
# Get from: https://shotstack.io/
SHOTSTACK_API_KEY=your-shotstack-api-key

# Serper API for trending topics and search
# Get from: https://serper.dev/dashboard
SERPER_API_KEY=your-serper-api-key

# ========================================
# n8n Automation Backend
# ========================================
# The public URL of your n8n workflow webhook
# This should point to your deployed n8n instance
# Example: https://your-n8n-instance.com/webhook/shortsforge-create-video
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/shortsforge-create-video

# ========================================
# Paddle Billing (Already configured)
# ========================================
# These may already exist from your existing setup
NEXT_PUBLIC_PADDLE_ENV=sandbox # or `production`
PADDLE_API_KEY=your-paddle-api-key
PADDLE_NOTIFICATION_WEBHOOK_SECRET=your-paddle-webhook-secret
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=your-paddle-client-token

# ========================================
# Next.js Configuration
# ========================================
# Your application URL (for webhook callbacks, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ========================================
# Social Media Platform Integrations
# ========================================
# YouTube Data API v3 for video uploads and user authentication
# Get from: https://console.developers.google.com/
YOUTUBE_CLIENT_ID=your-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/youtube/callback

# ========================================
# Additional Optional Configuration
# ========================================
# Sentry for error tracking (optional)
# SENTRY_DSN=your-sentry-dsn

# Analytics (optional)
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=your-google-analytics-id

# ========================================
# Development Notes
# ========================================
# 1. After setting up these environment variables:
#    - Run the Supabase migration: supabase db push
#    - Import the n8n workflow and deploy it
#    - Test the API endpoints
#
# 2. For production deployment:
#    - Change NEXT_PUBLIC_PADDLE_ENV to "production"
#    - Update N8N_WEBHOOK_URL to production endpoint
#    - Ensure all API keys are production-ready
#
# 3. Required API subscriptions:
#    - OpenRouter: Free tier available with Kimi K2 model, pay-per-use for premium models
#    - ElevenLabs: Monthly subscription for voice generation
#    - Pexels: Free tier available, paid for higher limits
#    - Shotstack: Pay-per-render for video generation
#
# 4. n8n Setup:
#    - Deploy n8n instance (cloud.n8n.io or self-hosted)
#    - Import the provided workflow JSON
#    - Configure Supabase credentials in n8n
#    - Set up API key secrets in n8n
#    - Activate the workflow and get the webhook URL
