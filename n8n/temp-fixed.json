    {
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "x-goog-api-key",
              "value": "{{ $secrets.GEMINI_API_KEY }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"contents\": [\n    {\n      \"parts\": [\n        {\n          \"text\": \"You are a TikTok content creator expert. Create engaging, concise scripts for {{ $('Get User Preferences').first().json.preferred_video_length || 15 }}-second videos that will go viral. Focus on hooks, trending topics, and engaging narratives that capture viewers' attention immediately.\\n\\nTONE: Use a {{ $('Get User Preferences').first().json.tone_of_voice || 'enthusiastic' }} tone throughout the script. Adapt your writing style accordingly:\\n- enthusiastic: Use excited, energetic language with exclamation points and dynamic phrases\\n- professional: Use clear, authoritative language that's informative yet engaging\\n- casual: Use relaxed, conversational language like talking to a friend\\n- humorous: Use wit, jokes, and playful language to entertain\\n\\nCreate a {{ $('Get User Preferences').first().json.preferred_video_length || 15 }}-second TikTok script about the trending topic: {{ $('Get Trend Data').first().json.title }}.\\n\\nDescription: {{ $('Get Trend Data').first().json.description }}\\n\\nSource: {{ $('Get Trend Data').first().json.source || 'General trend' }}\\n\\nContent Focus: Align the script with these content pillars: {{ ($('Get User Preferences').first().json.content_pillars || ['Education', 'Entertainment', 'Inspiration']).join(', ') }}. Make sure the content fits at least one of these themes.\\n\\nThe script should be {{ $('Get User Preferences').first().json.tone_of_voice || 'enthusiastic' }}, engaging, and include a strong hook in the first 3 seconds. Format it as direct speech without stage directions. Keep it under 100 words and make it sound natural for voiceover. End with the call-to-action: {{ $('Get User Preferences').first().json.default_cta || 'Like and follow for more!' }}\\n\\nRespond with ONLY the script text, no additional formatting or explanations.\"\n        }\n      ]\n    }\n  ],\n  \"generationConfig\": {\n    \"temperature\": 0.8,\n    \"maxOutputTokens\": 300\n  }\n}",
        "options": {}
      },
      "id": "e9691315-25dd-45a0-99d0-b5336007c055",
      "name": "Generate Script (Gemini)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [-5680, 16]
    },
    {
      "parameters": {
        "jsCode": "// Parse the Gemini API response\\nconst response = $input.first().json;\\n\\n// Extract text from Gemini response format\\nlet text = response.candidates?.[0]?.content?.parts?.[0]?.text || \\\"STOP scrolling - I'm about to show you the weirdest beauty hack trending right now! Instead of blending foundation with a sponge, grab a single latex glove... tap it in - and BOOM, glass-skin finish with zero fingerprints. This hack is exploding - cutting blending time in half, and people swear it looks airbrushed. Try it, tag me, and let's make this glow-up trend blow up!\\\";\\n\\n// 1. Remove \\\"0-3s:\\\", \\\"4-7s:\\\" style timestamps\\ntext = text.replace(/\\\\d+-\\\\d+s:\\\\s*/g, \\\"\\\");\\n\\n// 2. Remove everything after \\\"Word count:\\\" (metadata, CTA, etc.)\\ntext = text.replace(/Word count:[\\\\s\\\\S]*/i, \\\"\\\");\\n\\n// 3. Normalize curly quotes to straight quotes\\ntext = text.replace(/[""]/g, '\\\"').replace(/['']/g, \\\"'\\\");\\n\\n// 4. Replace line breaks with \\\\n (safe for JSON & ElevenLabs)\\ntext = text.replace(/\\\\r?\\\\n+/g, \\\"\\\\n\\\");\\n\\n// 5. Trim spaces\\ntext = text.trim();\\n\\nreturn {\\n  json: {\\n     script_text: JSON.stringify(text)\\n  }\\n};\\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-5456, 16],
      "id": "4921bdd6-fcd7-453e-a138-d027c75886c9",
      "name": "Process Script Text"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.elevenlabs.io/v1/text-to-speech/{{ $('Get User Preferences').first().json.ai_voice_id || 'JBFqnCBsd6RMkjVDRZzb' }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "xi-api-key",
              "value": "=sk_9e0cb01c454704ab6436acc54bfe81104197137d8540ee4a"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"text\": {{ $json.script_text }},\n  \"model_id\": \"eleven_multilingual_v2\",\n  \"voice_settings\": {\n    \"stability\": {{ (() => {\n      const tone = $('Get User Preferences').first().json.tone_of_voice || 'enthusiastic';\n      switch(tone) {\n        case 'professional': return 0.8;\n        case 'casual': return 0.4;\n        case 'humorous': return 0.3;\n        case 'enthusiastic':\n        default: return 0.5;\n      }\n    })() }},\n    \"similarity_boost\": {{ (() => {\n      const tone = $('Get User Preferences').first().json.tone_of_voice || 'enthusiastic';\n      switch(tone) {\n        case 'professional': return 0.8;\n        case 'casual': return 0.6;\n        case 'humorous': return 0.5;\n        case 'enthusiastic':\n        default: return 0.75;\n      }\n    })() }},\n    \"style\": {{ (() => {\n      const tone = $('Get User Preferences').first().json.tone_of_voice || 'enthusiastic';\n      switch(tone) {\n        case 'professional': return 0.2;\n        case 'casual': return 0.4;\n        case 'humorous': return 0.8;\n        case 'enthusiastic':\n        default: return 0.6;\n      }\n    })() }},\n    \"use_speaker_boost\": true\n  },\n  \"output_format\": \"mp3_44100_128\"\n}",
        "options": {
          "response": {
            "response": {}
          }
        }
      },
