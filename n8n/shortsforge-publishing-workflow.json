  {
    "parameters": {
      "jsCode": "// Handle publishing to both platforms\n// Split the data for parallel processing\nconst connections = $input.first().json;\nconst videoRecord = $('Get Video Record').first().json;\n\nconst videoData = {\n  title: videoRecord.title,\n  description: videoRecord.script_text,\n  videoUrl: videoRecord.final_video_url\n};\n\nconst tiktokConnection = connections.find(conn => \n  conn.platform === 'tiktok' && \n  conn.is_active && \n  new Date(conn.expires_at) > new Date()\n);\n\nconst youtubeConnection = connections.find(conn => \n  conn.platform === 'youtube' && \n  conn.is_active && \n  new Date(conn.expires_at) > new Date()\n);\n\nreturn [\n  {\n    json: {\n      platform: 'tiktok',\n      hasValidConnection: !!tiktokConnection,\n      connection: tiktokConnection,\n      accessToken: tiktokConnection?.access_token,\n      username: tiktokConnection?.platform_username,\n      videoData: videoData\n    }\n  },\n  {\n    json: {\n      platform: 'youtube',\n      hasValidConnection: !!youtubeConnection,\n      connection: youtubeConnection,\n      accessToken: youtubeConnection?.access_token,\n      refreshToken: youtubeConnection?.refresh_token,\n      channelId: youtubeConnection?.platform_username,\n      videoData: videoData\n    }\n  }\n];"
    },
