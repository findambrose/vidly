    "id": "f3a551c7-490a-46e3-9f33-7986fbed3a4f",
    "name": "Get Video File Size"
  },
  {
    "parameters": {
      "jsCode": "// Calculate video metadata for TikTok upload\nconst tiktokData = $('Prepare TikTok Data').item.json;\nconst response = $input.item;\n\n// Try to get video size from different possible sources\nlet videoSize = 50000000; // Default 50MB\n\n// Check if we have binary data and get its size\nif (response.binary && response.binary.videoFile) {\n  const binaryData = response.binary.videoFile;\n  if (binaryData.data && binaryData.data.length) {\n    videoSize = binaryData.data.length;\n  }\n} else if (response.headers && response.headers['content-length']) {\n  videoSize = parseInt(response.headers['content-length']);\n} else if (response.json && response.json.headers && response.json.headers['content-length']) {\n  videoSize = parseInt(response.json.headers['content-length']);\n}\n\n// Calculate chunk information\nconst chunkSize = Math.min(videoSize, 10000000); // 10MB chunks max\nconst totalChunkCount = Math.ceil(videoSize / chunkSize);\n\nconsole.log('Video metadata calculated:', {\n  videoSize,\n  chunkSize,\n  totalChunkCount\n});\n\nreturn {\n  json: {\n    ...tiktokData,\n    fileSize: videoSize,\n    chunkSize: chunkSize,\n    totalChunkCount: totalChunkCount\n  },\n  binary: {\n    videoFile: response.binary?.videoFile\n  }\n};"
    },
    "id": "calculate-video-metadata",
    "name": "Calculate Video Metadata",
    "type": "n8n-nodes-base.code",
    "typeVersion": 2,
    "position": [
      -6336,
      72
    ]
  }
