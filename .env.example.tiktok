# TikTok OAuth Configuration
# Get these from your TikTok for Developers account: https://developers.tiktok.com/

# TikTok App Client Key (from TikTok Developer Console)
TIKTOK_CLIENT_KEY=your_tiktok_client_key_here

# TikTok App Client Secret (from TikTok Developer Console)
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here

# TikTok OAuth Redirect URI (must match what's configured in TikTok Developer Console)
# For local development: http://localhost:3000/api/tiktok/callback
# For production: https://yourdomain.com/api/tiktok/callback
TIKTOK_REDIRECT_URI=http://localhost:3000/api/tiktok/callback

# TikTok API Base URL (usually doesn't need to change)
TIKTOK_API_BASE_URL=https://open.tiktokapis.com

# Instructions:
# 1. Create a TikTok for Developers account at https://developers.tiktok.com/
# 2. Create a new app in the TikTok Developer Console
# 3. Add the redirect URI to your app configuration
# 4. Copy the Client Key and Client Secret to this file
# 5. Rename this file to .env.local (for local development) or add to your production environment
# 6. Request the following scopes in your TikTok app:
#    - video.upload (required for uploading videos)
#    - user.info.profile (optional, for getting user profile info)

# Note: TikTok OAuth requires HTTPS in production. Make sure your redirect URI uses HTTPS for production deployments.